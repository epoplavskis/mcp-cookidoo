# Docker / GitHub Container Registry
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-pat-with-write-packages-scope
IMAGE=ghcr.io/your-github-username/mcp-cookidoo

# Cookidoo Credentials
COOKIDOO_EMAIL=your-email@example.com
COOKIDOO_PASSWORD=your-password-here

# HTTP server OIDC authentication (optional)
# When all required vars are set, the server requires OAuth 2.0 authentication.
# When any are missing, the server runs without authentication.
#
# Authentik example endpoints (replace <app-slug> with your application slug):
#   OIDC_AUTH_URL=https://auth.yourdomain.com/application/o/<app-slug>/authorize/
#   OIDC_TOKEN_URL=https://auth.yourdomain.com/application/o/token/
#   OIDC_JWKS_URI=https://auth.yourdomain.com/application/o/<app-slug>/jwks/
#   OIDC_ISSUER=https://auth.yourdomain.com/application/o/<app-slug>/

# Required
OIDC_CLIENT_ID=your-client-id
OIDC_AUTH_URL=https://auth.yourdomain.com/application/o/<app-slug>/authorize/
OIDC_TOKEN_URL=https://auth.yourdomain.com/application/o/token/
OIDC_JWKS_URI=https://auth.yourdomain.com/application/o/<app-slug>/jwks/
OIDC_ISSUER=https://auth.yourdomain.com/application/o/<app-slug>/
BASE_URL=https://mcp.yourdomain.com

# Optional
OIDC_CLIENT_SECRET=your-client-secret
JWT_SIGNING_KEY=a-random-secret-string-for-signing-internal-tokens
